<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <corners android:radius="42dp" />
    
    <!-- Semi-transparent light gradient to simulate frosted glass/jelly -->
    <gradient
        android:angle="135"
        android:startColor="#CCFFFFFF"
        android:centerColor="#99FFFFFF"
        android:endColor="#66FFFFFF"
        android:type="linear" />
        
    <!-- White reflective border -->
    <stroke
        android:width="1.5dp"
        android:color="#E6FFFFFF" />
</shape>
